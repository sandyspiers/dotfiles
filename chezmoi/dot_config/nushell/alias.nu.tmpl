# aliases and small named functions
{{ if eq .chezmoi.osRelease.id "arch" -}}
alias hx = helix
{{ end -}}
alias h = hx .
alias hxi = hx $in
alias ex = exit
alias ll = ls -a
alias cm = chezmoi
def pr [] { ps | where status =~ Running | sort-by cpu }
alias x = xdg-open

# zellij (defined in funcs.nu)
# alias zj = zellij-attach-git
# alias zf = zellij-attach-fzf

# julia
alias jl = julia -q --project --threads auto
def jlg [name: string] {
    let cmd = $"using Pkg; Pkg.generate\(\"($name)\"\)"
    julia -e $cmd
}
alias jls = julia -q --project=@LanguageServer

# git
alias lg = lazygit

# utils
alias helix-log = tail -f ~/.cache/helix/helix.log
